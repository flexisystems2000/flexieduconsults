        { "initial_1": "card", "initial_2": "guard", "medial_1": "prices", "medial_2": "prizes", "final_1": "", "final_2": "" },
        { "initial_1": "gear", "initial_2": "jeer", "medial_1": "", "medial_2": "", "final_1": "", "final_2": "" }
